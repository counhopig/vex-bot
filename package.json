{
  "name": "vex-bot",
  "version": "1.12.0",
  "description": "支持国产模型和国产通讯软件的智能助手机器人",
  "type": "module",
  "bin": {
    "vex": "./dist/cli/index.js"
  },
  "files": [
    "dist/**",
    "skills/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js start",
    "start:gateway": "tsx src/gateway/server.ts",
    "cli": "node dist/cli/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "pack:dry-run": "npm pack --dry-run --json",
    "pack:smoke": "npm run build && npm run pack:dry-run",
    "prepublishOnly": "npm run pack:smoke"
  },
  "keywords": [
    "chatbot",
    "ai",
    "llm",
    "deepseek",
    "minimax",
    "kimi",
    "moonshot",
    "stepfun",
    "weixin",
    "wechat",
    "chinese",
    "agent"
  ],
  "author": "King-Chau",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/King-Chau/vex.git"
  },
  "homepage": "https://github.com/King-Chau/vex#readme",
  "bugs": {
    "url": "https://github.com/King-Chau/vex/issues"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.58.3",
    "@mariozechner/pi-ai": "^0.58.3",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@sinclair/typebox": "^0.34.48",
    "axios": "^1.13.4",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "glob": "^13.0.0",
    "json5": "^2.2.3",
    "node-cache": "^5.1.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright-core": "^1.58.0",
    "ws": "^8.18.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/glob": "^8.1.0",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
